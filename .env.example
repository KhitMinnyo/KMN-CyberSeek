# KMN-CyberSeek Environment Configuration
# Copy this file to .env and update values as needed

# AI Configuration
AI_PROVIDER=local  # Options: "local" for Ollama, "api" for DeepSeek API
DEEPSEEK_API_KEY=your_deepseek_api_key_here  # Required if using API provider

# Security Settings
DEFAULT_RISK_THRESHOLD=medium  # low, medium, high
AUTO_APPROVE_LOW_RISK=true
MAX_AUTO_DEPTH=5  # Maximum consecutive auto-executed commands

# Network Settings
SCAN_TIMEOUT=300  # Seconds
MAX_CONCURRENT_SCANS=3

# Database Settings
DB_PATH=kmn_cyberseek.db

# Logging
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR
LOG_FILE=backend.log

# Development Settings
DEBUG=false
RELOAD=false

# Port Configuration
BACKEND_PORT=8000
FRONTEND_PORT=8501

# Tool Paths (if not in system PATH)
# NMAP_PATH=/usr/bin/nmap
# METASPLOIT_PATH=/usr/bin/msfconsole
